# LLM Providers
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# App Config
APP_ENV=development
LOG_LEVEL=DEBUG
PORT=8000

# Redis (for semantic caching)
REDIS_URL=redis://localhost:6379

# Vector DB
CHROMA_PERSIST_DIR=./data/chroma
# PGVECTOR_URL=postgresql://user:pass@localhost:5432/vectors  # for production

# Cost Tracking
MONTHLY_TOKEN_BUDGET=1000000
COST_ALERT_THRESHOLD=0.8

# Evaluation
EVAL_MODEL=gpt-4o-mini
EVAL_DATASET_PATH=./data/evals/
