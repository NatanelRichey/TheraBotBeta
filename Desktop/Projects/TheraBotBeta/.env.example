# LLM Providers — direct keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
DEEPSEEK_API_KEY=sk-...
KIMI_API_KEY=sk-...
DEEPSEEK_MODEL=deepseek-chat
KIMI_MODEL=moonshot-v1-8k

# LLM Providers — OpenRouter (one key replaces all of the above)
# When set, both default and cheap profiles route through OpenRouter instead of direct keys.
OPENROUTER_API_KEY=

# App Config
APP_ENV=development
LOG_LEVEL=DEBUG
PORT=8000

# Redis (for semantic caching)
REDIS_URL=redis://localhost:6379

# Vector DB
CHROMA_PERSIST_DIR=./data/chroma
# PGVECTOR_URL=postgresql://user:pass@localhost:5432/vectors  # for production

# Cost Tracking
MONTHLY_BUDGET_USD=10.0        # hard stop — raises 429 when exceeded
COST_ALERT_THRESHOLD=0.8       # log warning at 80% of budget

# Evaluation
EVAL_MODEL=gpt-4o-mini
EVAL_DATASET_PATH=./data/evals/
